{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hypernovelty Survival Card",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "domain",
    "audience",
    "problem",
    "practical_step",
    "caveat",
    "human_gate",
    "sources"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "audience": {
      "type": "string",
      "minLength": 1
    },
    "problem": {
      "type": "string",
      "minLength": 1
    },
    "practical_step": {
      "type": "string",
      "minLength": 1
    },
    "caveat": {
      "type": "string",
      "minLength": 1
    },
    "human_gate": {
      "type": "string",
      "minLength": 1
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
